<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="NowNext.App.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:presentation="using:NowNext.App.Presentation"
    Title="NOW/NEXT">
    <Grid
        x:Name="RootGrid"
        Loaded="OnRootLoaded">
        <Grid
            x:Name="TodayScreen"
            Padding="32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Spacing="4">
                    <TextBlock
                        x:Name="TodayHeading"
                        FontSize="32"
                        FontWeight="SemiBold"
                        Text="Today" />
                    <TextBlock
                        x:Name="TodayDateText"
                        FontSize="16"
                        Opacity="0.72" />
                </StackPanel>
                <Button
                    x:Name="AddTaskButton"
                    Grid.Column="1"
                    AutomationProperties.Name="Add a task to today"
                    Click="OnAddTaskClick"
                    Content="Add task"
                    MinHeight="44"
                    MinWidth="112" />
            </Grid>

            <ListView
                x:Name="TodayTaskList"
                Grid.Row="1"
                Margin="0,24,0,16"
                AutomationProperties.Name="Today's chronological tasks"
                ItemsSource="{x:Bind TodayItems, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="presentation:TodayTaskItem">
                        <Grid
                            MinHeight="104"
                            Padding="12"
                            ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="92" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <TextBlock
                                FontFamily="Consolas"
                                FontSize="18"
                                Text="{x:Bind PlannedStartText}"
                                VerticalAlignment="Top" />

                            <StackPanel
                                Grid.Column="1"
                                Spacing="4">
                                <TextBlock
                                    FontSize="19"
                                    FontWeight="SemiBold"
                                    Text="{x:Bind Task.FullTitle}" />
                                <TextBlock Text="{x:Bind Task.ShortFocusLabel}" />
                                <StackPanel
                                    Orientation="Horizontal"
                                    Spacing="12">
                                    <TextBlock
                                        FontWeight="SemiBold"
                                        Text="{x:Bind ScheduleText}" />
                                    <TextBlock Text="{x:Bind TimingText}" />
                                    <TextBlock Text="{x:Bind DurationText}" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel
                                Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                                <Button
                                    AutomationProperties.Name="{x:Bind StartAccessibilityName}"
                                    Click="OnStartTaskClick"
                                    Content="Start"
                                    MinHeight="44"
                                    MinWidth="76" />
                                <Button
                                    AutomationProperties.Name="{x:Bind MoveEarlierAccessibilityName}"
                                    Click="OnMoveEarlierClick"
                                    Content="Earlier"
                                    MinHeight="44" />
                                <Button
                                    AutomationProperties.Name="{x:Bind MoveLaterAccessibilityName}"
                                    Click="OnMoveLaterClick"
                                    Content="Later"
                                    MinHeight="44" />
                                <Button
                                    AutomationProperties.Name="{x:Bind EditAccessibilityName}"
                                    Click="OnEditTaskClick"
                                    Content="Edit"
                                    MinHeight="44" />
                                <Button
                                    AutomationProperties.Name="{x:Bind DeleteAccessibilityName}"
                                    Click="OnDeleteTaskClick"
                                    Content="Delete"
                                    MinHeight="44" />
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <StackPanel
                x:Name="EmptyTodayPanel"
                Grid.Row="1"
                HorizontalAlignment="Center"
                IsHitTestVisible="False"
                Spacing="8"
                VerticalAlignment="Center">
                <TextBlock
                    FontSize="22"
                    HorizontalAlignment="Center"
                    Text="No tasks planned yet." />
                <TextBlock
                    HorizontalAlignment="Center"
                    Opacity="0.72"
                    Text="Add the first concrete task for today." />
            </StackPanel>

            <TextBlock
                x:Name="StatusText"
                Grid.Row="2"
                AutomationProperties.LiveSetting="Polite"
                MinHeight="24"
                TextWrapping="Wrap" />
        </Grid>

        <Grid
            x:Name="FocusScreen"
            AutomationProperties.Name="Focus session"
            IsTabStop="True"
            KeyDown="OnFocusKeyDown"
            PointerMoved="OnFocusPointerMoved"
            PointerPressed="OnFocusPointerPressed"
            Tapped="OnFocusTapped"
            Visibility="Collapsed">
            <TextBlock
                x:Name="FocusLabelText"
                Margin="32,56,32,0"
                AutomationProperties.HeadingLevel="Level1"
                FontSize="28"
                FontWeight="SemiBold"
                HorizontalAlignment="Center"
                TextAlignment="Center"
                VerticalAlignment="Top" />

            <StackPanel
                x:Name="TimerDisplay"
                AutomationProperties.Name="Focus timer"
                HorizontalAlignment="Center"
                Orientation="Horizontal"
                VerticalAlignment="Center">
                <TextBlock
                    x:Name="TimerPrefixText"
                    FontFamily="Consolas"
                    FontSize="112" />
                <TextBlock
                    x:Name="TimerHoursText"
                    FontFamily="Consolas"
                    FontSize="112" />
                <TextBlock
                    x:Name="TimerFirstColonText"
                    FontFamily="Consolas"
                    FontSize="112"
                    Text=":" />
                <TextBlock
                    x:Name="TimerMinutesText"
                    FontFamily="Consolas"
                    FontSize="112"
                    Text="00" />
                <TextBlock
                    x:Name="TimerSecondColonText"
                    FontFamily="Consolas"
                    FontSize="112"
                    Text=":" />
                <TextBlock
                    x:Name="TimerSecondsText"
                    FontFamily="Consolas"
                    FontSize="112"
                    Text="00" />
            </StackPanel>

            <Border
                x:Name="FocusControls"
                Margin="24"
                Padding="16"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Visibility="Collapsed">
                <StackPanel Spacing="12">
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            x:Name="PauseResumeButton"
                            Click="OnPauseResumeClick"
                            MinHeight="44"
                            MinWidth="88" />
                        <Button
                            x:Name="FinishButton"
                            Click="OnFinishClick"
                            Content="Finish"
                            MinHeight="44" />
                        <Button
                            x:Name="ParkButton"
                            Click="OnParkClick"
                            Content="Park"
                            MinHeight="44" />
                        <Button
                            x:Name="LandingButton"
                            Click="OnLandingClick"
                            Content="Landing"
                            MinHeight="44" />
                        <Button
                            x:Name="ContinueButton"
                            Click="OnContinueClick"
                            Content="Continue overtime"
                            MinHeight="44" />
                        <Button
                            x:Name="HideControlsButton"
                            Click="OnHideControlsClick"
                            Content="Hide controls"
                            MinHeight="44" />
                    </StackPanel>
                    <StackPanel
                        HorizontalAlignment="Center"
                        Orientation="Horizontal"
                        Spacing="8">
                        <TextBlock
                            Text="Extend"
                            VerticalAlignment="Center" />
                        <Button
                            x:Name="ExtendFiveButton"
                            Click="OnExtendFiveClick"
                            Content="5 min"
                            MinHeight="44" />
                        <Button
                            x:Name="ExtendTenButton"
                            Click="OnExtendTenClick"
                            Content="10 min"
                            MinHeight="44" />
                        <Button
                            x:Name="ExtendFifteenButton"
                            Click="OnExtendFifteenClick"
                            Content="15 min"
                            MinHeight="44" />
                        <NumberBox
                            x:Name="CustomExtendMinutes"
                            AutomationProperties.Name="Custom extension minutes"
                            Header="Custom minutes"
                            Minimum="1"
                            SpinButtonPlacementMode="Compact"
                            Value="5"
                            Width="140" />
                        <Button
                            x:Name="CustomExtendButton"
                            Click="OnCustomExtendClick"
                            Content="Extend"
                            MinHeight="44" />
                    </StackPanel>
                    <TextBlock
                        x:Name="FocusControlError"
                        AutomationProperties.LiveSetting="Assertive"
                        HorizontalAlignment="Center"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                x:Name="RecoveryPanel"
                Margin="24"
                Padding="20"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8"
                HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Visibility="Collapsed">
                <StackPanel
                    MaxWidth="760"
                    Spacing="12">
                    <TextBlock
                        FontSize="20"
                        FontWeight="SemiBold"
                        Text="Focus was interrupted" />
                    <TextBlock
                        Text="Saved focused time is intact. Resume without the time away, or explicitly include a known amount."
                        TextWrapping="Wrap" />
                    <StackPanel
                        Orientation="Horizontal"
                        Spacing="8">
                        <Button
                            Click="OnResumeWithoutAwayClick"
                            Content="Resume — exclude time away"
                            MinHeight="44" />
                        <NumberBox
                            x:Name="IncludedAwayMinutes"
                            AutomationProperties.Name="Minutes away to include as focused time"
                            Header="Include minutes"
                            Minimum="0"
                            SpinButtonPlacementMode="Compact"
                            Value="0"
                            Width="150" />
                        <Button
                            Click="OnResumeIncludingAwayClick"
                            Content="Include and resume"
                            MinHeight="44" />
                        <Button
                            Click="OnFinishClick"
                            Content="Finish"
                            MinHeight="44" />
                        <Button
                            Click="OnParkClick"
                            Content="Park"
                            MinHeight="44" />
                    </StackPanel>
                    <TextBlock
                        x:Name="RecoveryError"
                        AutomationProperties.LiveSetting="Assertive"
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

        <ContentDialog
            x:Name="TaskEditorDialog"
            CloseButtonText="Cancel"
            DefaultButton="Primary"
            PrimaryButtonClick="OnTaskEditorPrimaryButtonClick"
            PrimaryButtonText="Save task"
            Visibility="Collapsed">
            <ScrollViewer MaxHeight="620">
                <StackPanel
                    MinWidth="520"
                    Spacing="12">
                    <TextBlock
                        x:Name="TaskEditorError"
                        AutomationProperties.LiveSetting="Assertive"
                        TextWrapping="Wrap" />
                    <TextBox
                        x:Name="FullTitleInput"
                        AutomationProperties.Name="Full title"
                        Header="Full title" />
                    <TextBox
                        x:Name="FocusLabelInput"
                        AutomationProperties.Name="Short focus label"
                        Header="Short focus label" />
                    <TextBox
                        x:Name="DefinitionOfDoneInput"
                        AcceptsReturn="True"
                        AutomationProperties.Name="Definition of done"
                        Header="Definition of done"
                        TextWrapping="Wrap" />
                    <TextBox
                        x:Name="FirstActionInput"
                        AutomationProperties.Name="First physical action"
                        Header="First physical action" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TimePicker
                            x:Name="PlannedStartInput"
                            AutomationProperties.Name="Planned start time"
                            Header="Planned start"
                            MinuteIncrement="5" />
                        <NumberBox
                            x:Name="DurationInput"
                            Grid.Column="1"
                            AutomationProperties.Name="Planned duration in minutes"
                            Header="Duration (minutes)"
                            SpinButtonPlacementMode="Compact"
                            Value="25" />
                    </Grid>
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox
                            x:Name="TimingModeInput"
                            AutomationProperties.Name="Timer mode"
                            Header="Timer mode"
                            SelectedIndex="0">
                            <ComboBoxItem Content="Count up" />
                            <ComboBoxItem Content="Countdown" />
                        </ComboBox>
                        <ComboBox
                            x:Name="ScheduleTypeInput"
                            Grid.Column="1"
                            AutomationProperties.Name="Schedule type"
                            Header="Schedule type"
                            SelectedIndex="1">
                            <ComboBoxItem Content="Fixed — protected" />
                            <ComboBoxItem Content="Flexible — movable" />
                        </ComboBox>
                        <ComboBox
                            x:Name="ImportanceInput"
                            Grid.Column="2"
                            AutomationProperties.Name="Importance"
                            Header="Importance"
                            SelectedIndex="0">
                            <ComboBoxItem Content="Normal" />
                            <ComboBoxItem Content="Important" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </ContentDialog>
    </Grid>
</Window>
